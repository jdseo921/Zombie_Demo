  behavior: 1
  displayName: Survivor A
  patrolSpeed: 1.2
  activeSpeed: 5
  wanderRadius: 6
  sightRange: 7
  sprintSightBonus: 1.3
  hearingRange: 10
  attackRange: 0.8
  attackCooldown: 1.2
  attackDamage: 1
  loseSightGrace: 2.5
  alertRadius: 10
  panicRange: 6
  calmDelay: 1.5
  fleeDistance: 8
  followPlayerWhenSafe: 1
  followEngageRange: 4.5
  followDistance: 1.2
  followLeashRange: 14
  followSpeed: 3
  anchoredUntilContact: 1
  hintLines:
  - We BOTH need to reach the green zone - my friend is hiding in the big building
    south of the road.
  - The extraction zone is on the far rooftop. The bridge connects them up here.
  - Stay off the road if you can - something fast prowls it.
  - Don't sprint near them - they hear it through walls.
  - They have to use the ramps, same as us. High ground buys time.
  hintLinesHurt:
  - Agh - it BIT me! Keep them off me, please.
  - I can take maybe one more hit... stay between me and them.
  - I'm slowing down... the green zone, quickly.
  hintLinesCritical:
  - One more bite and I'm done... please, the zone, NOW.
  - I can barely stand... don't let a single one near me.
  - If I fall, leave-- no. Don't. Just get me there.
  maxHealth: 3
  damageInvulnerability: 1
  showStateLabel: 1
  useStartCell: 1
  startCell: {x: 16, y: 45, z: 1}
  onAttack:
    m_PersistentCalls:
      m_Calls: []
